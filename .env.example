# Copy this file to .env and fill in your values

# Auth
# Visitors enter one of these first names to view the app.
# Names are comma-separated and case-insensitive.
# Keep people grouped here so each group can have its own explanatory comments.
LAB_NOTEBOOK_NAMES_LAB_MEMBERS=Alice,Bob
LAB_NOTEBOOK_NAMES_EUROPE_COLLABORATORS=Charlie,Dana
LAB_NOTEBOOK_NAMES_ASIAN_COLLABORATORS=Eunji,Fang
# Optional extra names that do not fit the groups above.
LAB_NOTEBOOK_ALLOWED_FIRST_NAMES=
# Fallback single password used only when all first-name lists are empty.
LAB_NOTEBOOK_PASSWORD=change-me
AUTH_SECRET=change-this-secret
AUTH_COOKIE_SECURE=false      # set to true if behind HTTPS
AUTH_TTL_SECONDS=28800        # 8 hours
AUTO_SCAN_ENABLED=true        # set to false on read-only mirror instances
LAB_NOTEBOOK_READ_ONLY=false  # set to true on remote rsync mirrors

# Host data directory mounted to /data in production compose.
# The app stores lab_notebook.db, notes, config, stock, and samples here.
DATA_DIR=./data
