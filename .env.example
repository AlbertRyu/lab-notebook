# Copy this file to .env and fill in your values

# Auth
LAB_NOTEBOOK_PASSWORD=change-me
AUTH_SECRET=change-this-secret
AUTH_COOKIE_SECURE=false      # set to true if behind HTTPS
AUTH_TTL_SECONDS=28800        # 8 hours
AUTO_SCAN_ENABLED=true        # set to false on read-only mirror instances
LAB_NOTEBOOK_READ_ONLY=false  # set to true on remote rsync mirrors

# Host data directory mounted to /data in production compose.
# The app stores lab_notebook.db, notes, config, stock, and samples here.
DATA_DIR=./data
