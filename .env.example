# Copy this file to .env and fill in your values

# Auth
LAB_NOTEBOOK_PASSWORD=change-me
AUTH_SECRET=change-this-secret
AUTH_COOKIE_SECURE=false      # set to true if behind HTTPS
AUTH_TTL_SECONDS=28800        # 8 hours

# Path to your experimental data folder on the host machine.
# Defaults to ./data/samples (inside the project folder).
# Change this to point to wherever your data lives, e.g.:
#   On Mac:          /Users/yourname/Documents/lab-data
#   On Raspberry Pi: /home/pi/lab-data
SAMPLES_DIR=./data/samples
